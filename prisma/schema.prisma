generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Post {
  id            String   @id @default(uuid())
  title         String
  slug          String   @unique
  content       String
  type          PostType
  author        String
  place         String
  publishedDate DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum PostType {
  bengali_poem
  english_poem
  article
}
